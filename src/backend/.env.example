# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic — powers chat, seniority classification, work log extraction
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase Postgres — use the Session Pooler URL (IPv4, port 5432)
# Found at: Supabase Dashboard → Settings → Database → Session Pooler
# Format: postgresql://postgres.PROJECTREF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.yourprojectref:yourpassword@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── Optional: Gmail API (LinkedIn + Indeed job alerts) ───────────────────────
# Without this, Email Alerts shows realistic mock data instead.
# No env vars needed — auth is handled via token.json (see setup below).
#
# Setup (run once):
#   1. console.cloud.google.com → New project → APIs & Services
#      → Enable "Gmail API" → Credentials → OAuth client ID (Desktop app)
#      → Download JSON → save as src/backend/credentials.json
#   2. python3 scripts/gmail_auth.py   ← opens browser, saves token.json
#
# After that, the app reads token.json automatically — no env vars needed.

# ── Optional: Apify (active job scraping from LinkedIn + Indeed) ──────────────
# Without this, job scraping returns realistic mock data instead.
# Get your token at: apify.com → Settings → Integrations → API tokens
APIFY_API_TOKEN=apify_api_your_token_here

# ── Optional: Resend (email notifications) ────────────────────────────────────
# Without these, notifications are previewed in the UI but not actually sent.
# Get your key at: resend.com → API Keys
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=Career Radar <notifications@yourdomain.com>

# Email address to receive job alerts and gap reminders
NOTIFICATION_EMAIL=you@example.com
